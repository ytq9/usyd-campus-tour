---
import { HomeIcon } from "@heroicons/react/20/solid";

import HotspotList from "./overlay/HotspotList.astro";
import MapModalStatic from "./overlay/MapModalStatic.astro";
import TitleDescription from "./overlay/TitleDescription.astro";

const {
  title = "sceneTitle",
  sceneId,
  floorId,
  nextHotSpots,
  globalConfig,
  sceneDescription,
} = Astro.props;
---

<div
  class="h-dvh w-dvw absolute pointer-events-none flex flex-col justify-between"
>
  <div class="w-full flex flex-row justify-between">
    <div class="w-1/3"></div>
    <div class="sm:1/3 lg:w-1/2 mt-4 text-white text-xl text-center">
      <TitleDescription title={title} sceneDescription={sceneDescription} />
    </div>
    <HotspotList nextHotSpots={nextHotSpots} />
  </div>
  <div>{/* center */}</div>
  <div class="w-full flex flex-row">
    <div
      class="bg-black/60 p-6 pl-4 rounded-r-xl mb-10 pointer-events-auto flex flex-row space-x-2"
    >
      <button
        data-a
        data-sceneId=""
        data-floorId=""
        data-isNewFloorScene="newFloorScene"
        class="bg-ochre hover:bg-orange-700 p-2 size-14 rounded-full cursor-pointer"
      >
        <HomeIcon className="size-6 m-auto fill-white" />
      </button>

      <MapModalStatic
        transition:persist={floorId}
        globalConfig={globalConfig}
        sceneId={sceneId}
      />
    </div>
    <div class="">{/* center */}</div>
    <div class="">{/* right */}</div>
  </div>
</div>
