---

<div slot="fallback">
  <style>
    /* Container providing perspective */
    .scene {
      width: 150px;
      height: 150px;
      perspective: 600px;
      margin: 2rem auto;
    }

    /* The cube element */
    .cube {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
      animation: spin 5s infinite linear;
    }

    /* All faces share these base styles */
    .cube div {
      position: absolute;
      width: 150px;
      height: 150px;
      background: rgba(0, 128, 255, 0.8);
      border: 2px solid #fff;
      box-sizing: border-box;
    }

    /* Positioning each face */
    .front {
      transform: translateZ(75px);
    }
    .back {
      transform: rotateY(180deg) translateZ(75px);
    }
    .right {
      transform: rotateY(90deg) translateZ(75px);
    }
    .left {
      transform: rotateY(-90deg) translateZ(75px);
    }
    .top {
      transform: rotateX(90deg) translateZ(75px);
    }
    .bottom {
      transform: rotateX(-90deg) translateZ(75px);
    }

    /* Animation for spinning the cube */
    @keyframes spin {
      from {
        transform: rotateX(0deg) rotateY(0deg);
      }
      to {
        transform: rotateX(360deg) rotateY(360deg);
      }
    }
  </style>
  <div class="flex items-center justify-center h-dvh w-dvw inset-0 absolute">
    <div class="scene">
      <div class="cube">
        <div class="front"></div>
        <div class="back"></div>
        <div class="right"></div>
        <div class="left"></div>
        <div class="top"></div>
        <div class="bottom"></div>
      </div>
    </div>
  </div>
</div>
